.git
.DS_Store
node_modules
.venv_shorts/
.venv_youtube/
*.log
logs/*.pid

# Python bytecode
__pycache__/
*.pyc
*.pyo

# YouTube OAuth secrets — NEVER commit
scripts/youtube_token*.json
scripts/youtube_client_secret*.json

# YouTube upload state (ephemeral, rebuilt on each run)
scripts/youtube_channel_state.json
scripts/youtube_shorts_state.json
scripts/youtube_uploaded.txt

# Local audio artifacts (published in the separate openclaw-podcast-audio repo)
audio/
*.mp3

# Temp / scratch directories
tmp_short_test/

# Local staging output (final assets live in audio/CDN, translations/<lang>/, or YouTube)
content_staging/
youtube_shorts_ep*/

# Rejected/unreleased local backups; use macOS Trash or external archival, not Git
archive/

# Local/private scratch notes and one-off review artifacts
MEMORY.md
SHORTS_ALGORITHM_REVIEW_*.md
episodes/*.bak.md
episodes/latoya_brief_daily_tts.md
episodes/special_*_transcript.md
show_notes_*_special.md

# Generated channel setup graphics; publish/copy these from asset workspaces, not Git here
images/youtube_banners/
images/youtube_profiles/

# Old one-off local maintenance helpers and state
scripts/build_latoya_daily_tts_script.py
scripts/run_latoya_daily_tts.sh
scripts/tts_remote_queue.json
scripts/build_low_performing_youtube_thumbnails.py
scripts/check_youtube_packaging_lift.py
scripts/update_youtube_packaging.py
scripts/youtube_packaging_*.json
scripts/generate_episode_*_cover.py

# Generated episode-art modules are local-only build intermediates (2026-06-10).
# The final cover PNGs stay in git via the release flow; the module that drew
# them is reproducible from generate_episode_art.py and has no standalone value.
scripts/episode_art/

# Intermediate OpenAI art renders consumed by the cover compositor; the final
# images/episode_0NN_cover*.png are the tracked artifacts
images/episode_*_openai_art.png

# Intermediate TTS render files (generated by render_nova.py, not source)
*_nova.md

# Per-episode release state (ephemeral pipeline state)
scripts/release_ep*.json
scripts/release_ep*.json.bak-*

# Runtime caches (rebuilt every research run)
scripts/last_seen_models.json
scripts/.telegram_send_records/

# Pipeline debris — rejected QC drafts, scratch, and trash (never commit)
episodes/.episode_*_transcript.*.tmp
*.rejected.*
trash/
scripts/.sol_repair_state.json
